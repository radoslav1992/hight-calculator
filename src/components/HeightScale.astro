  }

  .scale-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .scale-heading div {
    display: grid;
    gap: 0.25rem;
  }

  .scale-heading span {
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scale-heading strong {
    font-size: 1.1rem;
  }

  .scale-note {
    color: #666;
    text-align: right;
  }

  svg {
    display: block;
    width: 100%;
    overflow: visible;
  }

  .axis,
  .tick {
    stroke: var(--color-ink);
    stroke-width: 3;
  }

  text {
    fill: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 900;
  }

  .average-marker line {
    stroke: #777;
    stroke-dasharray: 5 4;
    stroke-width: 2;
  }

  .average-marker text {
    fill: #555;
    font-size: 11px;
  }

  .range {
    fill: var(--color-sky);
    stroke: var(--color-ink);
    stroke-width: 3;
  }

  .estimate-marker path {
    fill: var(--color-coral);
    stroke: var(--color-ink);
    stroke-width: 3;
  }

  .estimate-marker line {
    stroke: var(--color-ink);
    stroke-width: 3;
  }

  .estimate-marker text {
    font-size: 13px;
  }
</style>
