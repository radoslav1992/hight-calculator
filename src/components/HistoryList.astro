<section class="history brutal-card" aria-labelledby="history-title">
  <div class="history-heading">
    <div>
      <p class="eyebrow">On this device</p>
      <h2 id="history-title">Prediction history</h2>
    </div>
    <button type="button" data-clear-history hidden>Clear all</button>
  </div>
  <p class="history-intro">Saved locally in this browser—never uploaded, shared, or tied to an account.</p>
  <div data-history-empty class="empty-history">
    <span>01</span>
    <div>
      <strong>No saved predictions yet.</strong>
      <p>Complete the calculator and your latest result will appear here.</p>
    </div>
  </div>
  <div class="history-list" data-history-list></div>
</section>

<script>
  import { formatImperial } from "../utils/engine";
  import { clearHistory, getHistory, removePrediction, type HistoryRecord } from "../utils/storage";

  const list = document.querySelector<HTMLElement>("[data-history-list]");
  const empty = document.querySelector<HTMLElement>("[data-history-empty]");
  const clearButton = document.querySelector<HTMLButtonElement>("[data-clear-history]");

  function createRecord(record: HistoryRecord): HTMLElement {
    const article = document.createElement("article");
    article.className = "history-record";

    const main = document.createElement("div");
    const name = document.createElement("strong");
    name.textContent = record.input.name?.trim() || "Saved prediction";
    const meta = document.createElement("span");
    meta.textContent = `${record.input.ageYears} years · ${new Intl.DateTimeFormat(undefined, { month: "short", day: "numeric", year: "numeric" }).format(new Date(record.createdAt))}`;
    main.append(name, meta);

    const height = document.createElement("div");
    height.className = "history-height";
    const metric = document.createElement("strong");
    metric.textContent = `${record.result.estimateCm.toFixed(1)} cm`;
    const imperial = document.createElement("span");
    imperial.textContent = formatImperial(record.result.estimateCm);
    height.append(metric, imperial);

    const remove = document.createElement("button");
    remove.type = "button";
    remove.setAttribute("aria-label", `Remove ${name.textContent}`);
    remove.textContent = "×";
    remove.addEventListener("click", () => render(removePrediction(record.id)));

    article.append(main, height, remove);
    return article;
  }

  function render(records: HistoryRecord[] = getHistory()) {
    if (!list || !empty || !clearButton) return;
    list.replaceChildren(...records.map(createRecord));
    empty.hidden = records.length > 0;
    clearButton.hidden = records.length === 0;
  }

  clearButton?.addEventListener("click", () => {
    clearHistory();
    render([]);
  });
  window.addEventListener("tallwise:history", (event) => {
    render((event as CustomEvent<HistoryRecord[]>).detail);
  });
  render();
</script>

<style>
  .history {
    padding: clamp(1.25rem, 4vw, 2rem);
    background: var(--color-violet);
  }

  .history-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .history-heading > div {
    display: grid;
    gap: 0.85rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    letter-spacing: -0.05em;
    line-height: 1;
    text-transform: uppercase;
  }

  .history-heading button,
  .history-record button {
    border: 2px solid var(--color-ink);
    background: white;
    box-shadow: 2px 2px 0 var(--color-ink);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
  }

  .history-heading button {
    padding: 0.5rem 0.65rem;
  }

  .history-intro {
    max-width: 650px;
    margin: 0.85rem 0 1.4rem;
    line-height: 1.55;
  }

  .empty-history,
  :global(.history-record) {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1rem;
    border: 3px solid var(--color-ink);
    padding: 1rem;
    background: white;
  }

  .empty-history > span {
    font-family: var(--font-display);
    font-size: 2rem;
  }

  .empty-history p {
    margin: 0.2rem 0 0;
    color: #555;
    font-size: 0.86rem;
  }

  .history-list {
    display: grid;
    gap: 0.75rem;
  }

  :global(.history-record) {
    grid-template-columns: 1fr auto auto;
  }

  :global(.history-record > div:first-child),
  :global(.history-height) {
    display: grid;
    gap: 0.2rem;
  }

  :global(.history-record span) {
    color: #666;
    font-size: 0.72rem;
    font-weight: 700;
  }

  :global(.history-height) {
    min-width: 90px;
    text-align: right;
  }

  :global(.history-record button) {
    width: 32px;
    height: 32px;
    font-size: 1rem;
  }

  @media (max-width: 520px) {
    :global(.history-record) {
      grid-template-columns: 1fr auto;
    }

    :global(.history-height) {
      grid-column: 1;
      grid-row: 2;
      text-align: left;
    }

    :global(.history-record button) {
      grid-column: 2;
      grid-row: 1 / 3;
    }
  }
</style>
