---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Calculator" },
  { href: "/advice/", label: "Advice" },
  { href: "/about/", label: "The science" }
];
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="Tallwise home">
      <svg viewBox="0 0 42 42" aria-hidden="true">
        <rect x="2" y="2" width="38" height="38" rx="7" fill="#b8f06a" stroke="#171717" stroke-width="3"></rect>
        <path d="M12 31V11h19v20M18 15v16M18 21h8M18 26h5" fill="none" stroke="#171717" stroke-width="3"></path>
        <circle cx="30" cy="12" r="4" fill="#ff6b57" stroke="#171717" stroke-width="2"></circle>
      </svg>
      <span>Tallwise</span>
    </a>

    <nav aria-label="Primary navigation">
      {links.map((link) => (
        <a href={link.href} aria-current={pathname === link.href ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>

    <button class="install-button" type="button" data-install-app hidden>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 20h14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" /></svg>
      Install app
    </button>
  </div>
</header>

<script>
  type InstallPromptEvent = Event & {
    prompt: () => Promise<void>;
    userChoice: Promise<{ outcome: "accepted" | "dismissed" }>;
  };

  let installPrompt: InstallPromptEvent | undefined;
  const installButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-install-app]"));

  window.addEventListener("beforeinstallprompt", (event) => {
    event.preventDefault();
    installPrompt = event as InstallPromptEvent;
    installButtons.forEach((button) => (button.hidden = false));
  });

  installButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      if (!installPrompt) return;
      await installPrompt.prompt();
      const { outcome } = await installPrompt.userChoice;
      if (outcome === "accepted") {
        installButtons.forEach((item) => (item.hidden = true));
      }
      installPrompt = undefined;
    });
  });

  window.addEventListener("appinstalled", () => {
    installButtons.forEach((button) => (button.hidden = true));
    installPrompt = undefined;
  });
</script>

<style>
  .site-header {
    position: sticky;
    z-index: 50;
    top: 0;
    border-bottom: 3px solid var(--color-ink);
    background: rgba(255, 253, 245, 0.96);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    display: flex;
    min-height: 76px;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .brand svg {
    width: 42px;
    height: 42px;
  }

  nav {
    display: flex;
    align-items: stretch;
    gap: 0.15rem;
    margin-left: auto;
  }

  nav a {
    padding: 0.7rem 0.8rem;
    font-size: 0.78rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
  }

  nav a:hover,
  nav a[aria-current="page"] {
    background: var(--color-sun);
    box-shadow: inset 0 -3px 0 var(--color-ink);
  }

  .install-button {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    gap: 0.4rem;
    border: 2px solid var(--color-ink);
    padding: 0.55rem 0.75rem;
    background: var(--color-lime);
    box-shadow: 3px 3px 0 var(--color-ink);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
  }

  .install-button[hidden] {
    display: none;
  }

  .install-button svg {
    width: 18px;
  }

  @media (max-width: 760px) {
    .header-inner {
      min-height: 64px;
      gap: 0.65rem;
    }

    .brand span {
      display: none;
    }

    .brand svg {
      width: 38px;
      height: 38px;
    }

    nav {
      margin-left: 0;
    }

    nav a {
      padding: 0.6rem 0.45rem;
      font-size: 0.68rem;
    }

    .install-button {
      margin-left: auto;
      padding: 0.5rem;
      font-size: 0;
    }
  }
</style>
