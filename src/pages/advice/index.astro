---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import AdUnit from "../../components/AdUnit.astro";

const entries = (await getCollection("advice")).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured) || a.data.title.localeCompare(b.data.title)
);
const categories = ["Genetics & science", "Nutrition & sleep", "Growth timelines"] as const;
const colors = ["lime", "sky", "coral", "violet", "sun"];
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Child Growth Advice Library",
  description: "Evidence-minded guides about height prediction, puberty, sleep, and nutrition for families.",
  url: new URL("/advice/", Astro.site).toString(),
  hasPart: entries.map((entry) => ({
    "@type": "Article",
    headline: entry.data.title,
    url: new URL(`/advice/${entry.id}/`, Astro.site).toString()
  }))
};
---

<Layout
  title="Child Growth & Height Advice for Parents | Tallwise"
  description="Explore clear, evidence-minded guides to child height prediction, puberty timelines, sleep, nutrition, and growth charts."
  schema={schema}
>
  <header class="hub-hero">
    <div class="shell hero-layout">
      <div>
        <p class="eyebrow">The Tallwise field guide</p>
        <h1 class="display-title">Growth,<br /><em>decoded.</em></h1>
      </div>
      <div class="hero-side">
        <p>Clear answers for the questions behind the calculator—without miracle claims, panic, or medical jargon.</p>
        <a class="brutal-button" href="/#calculator">Try the calculator →</a>
      </div>
    </div>
  </header>

  <section class="hub-content page-section">
    <div class="shell">
      <div class="filter-row">
        <div class="search-box">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.5" /><path d="m15.5 15.5 5 5" stroke="currentColor" stroke-width="2.5" /></svg>
          <label class="sr-only" for="guide-search">Search guides</label>
          <input id="guide-search" type="search" placeholder="Search the library…" data-guide-search />
        </div>
        <div class="category-buttons" aria-label="Filter by category">
          <button type="button" data-category="all" aria-pressed="true">All</button>
          {categories.map((category) => <button type="button" data-category={category} aria-pressed="false">{category}</button>)}
        </div>
      </div>

      <div class="category-intro">
        <span data-result-count>{entries.length} guides</span>
        <p>Reviewed for plain language, transparent limits, and practical next steps.</p>
      </div>

      <div class="article-grid" data-article-grid>
        {entries.map((entry, index) => (
          <article class="article-card brutal-card" data-guide-card data-category-value={entry.data.category} data-search-value={`${entry.data.title} ${entry.data.summary} ${entry.data.category}`.toLowerCase()}>
            <div class:list={["card-art", colors[index % colors.length]]}>
              <span>0{index + 1}</span>
              <svg viewBox="0 0 160 100" aria-hidden="true">
                <path d="M10 82h140M25 70c22-6 28-27 48-27s25-25 61-32" fill="none" stroke="currentColor" stroke-width="7" stroke-dasharray="10 7" />
                <circle cx="73" cy="43" r="9" fill="#fffdf5" stroke="currentColor" stroke-width="5" />
              </svg>
            </div>
            <div class="card-copy">
              <small>{entry.data.category} · {entry.data.readTime}</small>
              <h2><a href={`/advice/${entry.id}/`}>{entry.data.title}</a></h2>
              <p>{entry.data.summary}</p>
              <a class="card-link" href={`/advice/${entry.id}/`}>Read the guide →</a>
            </div>
          </article>
        ))}
      </div>

      <p class="no-results" data-no-results hidden>No guides match that search. Try a broader term.</p>

      <div class="ad-wrap"><AdUnit placement="advice-hub-native" format="native" /></div>

      <section class="category-band brutal-card">
        <div>
          <span>01</span>
          <h2>Genetics & science</h2>
          <p>Understand the models, their evidence, and the limits behind every result.</p>
        </div>
        <div>
          <span>02</span>
          <h2>Nutrition & sleep</h2>
          <p>Support healthy development without confusing good habits with height promises.</p>
        </div>
        <div>
          <span>03</span>
          <h2>Growth timelines</h2>
          <p>Make sense of puberty, velocity, and why every child's schedule looks different.</p>
        </div>
      </section>
    </div>
  </section>
</Layout>

<script>
  const search = document.querySelector<HTMLInputElement>("[data-guide-search]");
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-category]"));
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-guide-card]"));
  const count = document.querySelector<HTMLElement>("[data-result-count]");
  const empty = document.querySelector<HTMLElement>("[data-no-results]");
  let category = "all";

  function filterGuides() {
    const term = search?.value.trim().toLowerCase() ?? "";
    let visible = 0;
    cards.forEach((card) => {
      const categoryMatch = category === "all" || card.dataset.categoryValue === category;
      const searchMatch = !term || card.dataset.searchValue?.includes(term);
      card.hidden = !(categoryMatch && searchMatch);
      if (!card.hidden) visible += 1;
    });
    if (count) count.textContent = `${visible} guide${visible === 1 ? "" : "s"}`;
    if (empty) empty.hidden = visible > 0;
  }

  search?.addEventListener("input", filterGuides);
  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      category = button.dataset.category ?? "all";
      buttons.forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
      filterGuides();
    });
  });
</script>

<style>
  .hub-hero {
    border-bottom: 3px solid var(--color-ink);
    padding: clamp(3rem, 8vw, 7rem) 0;
    background: var(--color-violet);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1.5fr 0.6fr;
    align-items: end;
    gap: clamp(2rem, 7vw, 6rem);
  }

  .hero-layout > div:first-child {
    display: grid;
    gap: 1.4rem;
  }

  .display-title em {
    color: var(--color-lime);
    font-style: normal;
    text-shadow: 4px 4px 0 var(--color-ink);
    -webkit-text-stroke: 3px var(--color-ink);
  }

  .hero-side {
    display: grid;
    gap: 1.4rem;
  }

  .hero-side p {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.55;
  }

  .hub-content {
    background: #f3f0e5;
  }

  .filter-row {
    display: grid;
    grid-template-columns: minmax(260px, 0.7fr) 1fr;
    gap: 1rem;
  }

  .search-box {
    display: flex;
    min-height: 54px;
    align-items: center;
    gap: 0.6rem;
    border: 3px solid var(--color-ink);
    padding: 0.6rem 0.8rem;
    background: white;
    box-shadow: 4px 4px 0 var(--color-ink);
  }

  .search-box svg {
    width: 24px;
    flex: 0 0 auto;
  }

  .search-box input {
    width: 100%;
    border: 0;
    outline: 0;
    font-weight: 800;
  }

  .category-buttons {
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-buttons button {
    border: 2px solid var(--color-ink);
    padding: 0.6rem 0.75rem;
    background: white;
    font-size: 0.67rem;
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
  }

  .category-buttons button[aria-pressed="true"] {
    background: var(--color-sun);
    box-shadow: 3px 3px 0 var(--color-ink);
  }

  .category-intro {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 2.5rem 0 1.2rem;
    border-bottom: 3px solid var(--color-ink);
    padding-bottom: 0.8rem;
  }

  .category-intro span {
    font-family: var(--font-display);
    font-size: 1.4rem;
    text-transform: uppercase;
  }

  .category-intro p {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem;
  }

  .article-card {
    display: grid;
    grid-template-columns: 190px 1fr;
    overflow: hidden;
    min-height: 310px;
    background: white;
  }

  .card-art {
    position: relative;
    overflow: hidden;
    border-right: 3px solid var(--color-ink);
    padding: 1rem;
  }

  .card-art.lime { background: var(--color-lime); }
  .card-art.sky { background: var(--color-sky); }
  .card-art.coral { background: var(--color-coral); }
  .card-art.violet { background: var(--color-violet); }
  .card-art.sun { background: var(--color-sun); }

  .card-art span {
    font-family: var(--font-display);
    font-size: 2.8rem;
  }

  .card-art svg {
    position: absolute;
    right: -15px;
    bottom: 25px;
    width: 170px;
  }

  .card-copy {
    display: flex;
    flex-direction: column;
    padding: 1.2rem;
  }

  .card-copy small {
    font-size: 0.64rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .card-copy h2 {
    margin: 0.8rem 0 0.6rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .card-copy h2 a {
    text-decoration: none;
  }

  .card-copy h2 a:hover {
    text-decoration: underline;
    text-decoration-thickness: 3px;
  }

  .card-copy p {
    margin: 0;
    color: #555;
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .card-link {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.7rem;
    font-weight: 900;
    text-underline-offset: 4px;
    text-transform: uppercase;
  }

  .no-results {
    border: 3px solid var(--color-ink);
    padding: 2rem;
    background: white;
    box-shadow: 6px 6px 0 var(--color-ink);
    font-weight: 900;
    text-align: center;
  }

  .ad-wrap {
    margin: 3rem 0;
  }

  .category-band {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    overflow: hidden;
    margin-top: 3rem;
    background: white;
  }

  .category-band > div {
    min-height: 220px;
    padding: 1.2rem;
  }

  .category-band > div + div {
    border-left: 3px solid var(--color-ink);
  }

  .category-band span {
    font-family: var(--font-display);
    font-size: 2rem;
  }

  .category-band h2 {
    margin: 1.8rem 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    text-transform: uppercase;
  }

  .category-band p {
    margin: 0;
    color: #555;
    font-size: 0.84rem;
    line-height: 1.5;
  }

  @media (max-width: 950px) {
    .article-card {
      grid-template-columns: 1fr;
    }

    .card-art {
      min-height: 150px;
      border-right: 0;
      border-bottom: 3px solid var(--color-ink);
    }
  }

  @media (max-width: 700px) {
    .hero-layout,
    .filter-row,
    .article-grid,
    .category-band {
      grid-template-columns: 1fr;
    }

    .category-buttons {
      justify-content: flex-start;
    }

    .category-intro {
      align-items: flex-start;
      flex-direction: column;
    }

    .category-band > div + div {
      border-top: 3px solid var(--color-ink);
      border-left: 0;
    }
  }
</style>
