---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Calculator from "../components/Calculator.astro";
import HistoryList from "../components/HistoryList.astro";

const guides = (await getCollection("advice"))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 3);

const faq = [
  {
    question: "How accurate is a child height calculator?",
    answer:
      "It can provide a useful educational estimate, not an exact forecast. Accuracy varies with age, measurement quality, puberty timing, health, and how closely the child matches the populations behind each model."
  },
  {
    question: "What ages does Tallwise support?",
    answer:
      "The full estimator supports ages 4 through 17.5 because that is the age range of the Khamis–Roche coefficient table used by the primary model."
  },
  {
    question: "Does Tallwise upload my child's measurements?",
    answer:
      "No. Calculations happen in your browser and saved predictions stay in localStorage on the current device. The default build has no analytics, account, database, or active advertising."
  },
  {
    question: "Can sleep or nutrition make a child taller?",
    answer:
      "Adequate sleep and nutrition support normal development, but no routine or food can guarantee extra height beyond biological potential. Tallwise keeps these adjustments deliberately small."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Tallwise Child Height Calculator",
    applicationCategory: "HealthApplication",
    operatingSystem: "Any web browser",
    url: Astro.site?.toString(),
    description:
      "A private adult-height estimator combining Khamis–Roche, mid-parental target height, and CDC growth-reference projection.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    featureList: [
      "Runs entirely in the browser",
      "Khamis–Roche age-specific calculation",
      "CDC stature-for-age reference projection",
      "Local prediction history",
      "Offline-capable progressive web app"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer }
    }))
  }
];
---

<Layout
  title="Child Height Calculator & Adult Height Predictor | Tallwise"
  description="Estimate your child's adult height with Khamis–Roche, parent-height, and CDC growth-curve models. Private, free, and processed entirely in your browser."
  schema={schema}
>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">A private growth estimator</p>
        <h1 class="display-title">How tall<br />might they<br /><em>grow?</em></h1>
        <p class="hero-lede">One transparent estimate. Three established perspectives. A realistic range instead of a magic number.</p>
        <div class="hero-actions">
          <a class="brutal-button" href="#calculator">Start the estimate <span aria-hidden="true">↓</span></a>
          <a class="text-link" href="/about/">See the methodology →</a>
        </div>
        <div class="hero-trust">
          <span><b>100%</b> on-device</span>
          <span><b>0</b> accounts</span>
          <span><b>3</b> model views</span>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="ruler-card brutal-card">
          <div class="ruler-top"><span>Growth is a journey</span><b>cm</b></div>
          <div class="ruler-body">
            {[200, 190, 180, 170, 160, 150, 140].map((number) => (
              <div class="ruler-line"><span>{number}</span><i></i></div>
            ))}
            <div class="range-sticker">
              <small>Prediction</small>
              <strong>not<br />a promise</strong>
            </div>
            <svg class="growth-arrow" viewBox="0 0 150 230">
              <path d="M22 205C36 160 52 166 58 126S92 92 116 40" fill="none" stroke="#171717" stroke-width="6" stroke-linecap="square" stroke-dasharray="10 9"></path>
              <path d="m97 45 24-12 4 26" fill="none" stroke="#171717" stroke-width="6"></path>
            </svg>
          </div>
        </div>
        <span class="hero-note note-one">No X-ray</span>
        <span class="hero-note note-two">Works offline</span>
      </div>
    </div>
  </section>

  <div class="principle-strip" aria-label="Tallwise principles">
    <div class="marquee-track">
      <span>Private by design</span><i>✦</i><span>Evidence-minded</span><i>✦</i><span>Built for families</span><i>✦</i><span>Educational, never diagnostic</span><i>✦</i>
    </div>
  </div>

  <section class="calculator-section page-section">
    <div class="shell calculator-heading">
      <div>
        <p class="eyebrow">Takes about 60 seconds</p>
        <h2 class="section-title">Measure.<br />Estimate.<br />Understand.</h2>
      </div>
      <p>For children ages 4 to 17½. Use recent measurements and biological parent heights when available.</p>
    </div>
    <div class="shell"><Calculator /></div>
  </section>

  <section class="history-section page-section">
    <div class="shell"><HistoryList /></div>
  </section>

  <section class="method-section page-section">
    <div class="shell">
      <div class="method-heading">
        <div>
          <p class="eyebrow">No black box</p>
          <h2 class="section-title">Three angles.<br />One honest range.</h2>
        </div>
        <p>Each model sees a different part of the picture. Tallwise shows their outputs instead of hiding the disagreement.</p>
      </div>
      <div class="method-cards">
        <article class="method-card brutal-card lime-card">
          <span>01 / Primary</span>
          <svg viewBox="0 0 100 100" aria-hidden="true"><path d="M20 82V20h60v62M30 32h20M30 45h34M30 58h24" fill="none" stroke="currentColor" stroke-width="6" /></svg>
          <h3>Khamis–Roche</h3>
          <p>Age, sex, current height, current weight, and average parent height with half-year coefficients.</p>
        </article>
        <article class="method-card brutal-card sky-card">
          <span>02 / Genetic anchor</span>
          <svg viewBox="0 0 100 100" aria-hidden="true"><circle cx="29" cy="28" r="13" fill="none" stroke="currentColor" stroke-width="6" /><circle cx="71" cy="28" r="13" fill="none" stroke="currentColor" stroke-width="6" /><path d="M15 78c2-18 9-27 21-27s19 9 21 27M48 78c2-18 9-27 21-27s19 9 21 27" fill="none" stroke="currentColor" stroke-width="6" /></svg>
          <h3>Parent target</h3>
          <p>The Tanner mid-parent formula creates a broad genetic midpoint with a conventional ±8.5 cm band.</p>
        </article>
        <article class="method-card brutal-card coral-card">
          <span>03 / Trajectory</span>
          <svg viewBox="0 0 100 100" aria-hidden="true"><path d="M13 80h74M19 72c14-5 14-25 29-25s15-25 34-31" fill="none" stroke="currentColor" stroke-width="6" /><circle cx="48" cy="47" r="6" fill="#fffdf5" stroke="currentColor" stroke-width="4" /></svg>
          <h3>CDC curve</h3>
          <p>Today's stature-for-age z-score is mapped to the same position on the age-20 CDC reference.</p>
        </article>
      </div>
      <a class="brutal-button dark method-link" href="/about/">Read the full science →</a>
    </div>
  </section>

  <section class="guides-section page-section">
    <div class="shell">
      <div class="guides-heading">
        <div>
          <p class="eyebrow">Parent-friendly research</p>
          <h2 class="section-title">Grow your<br />understanding.</h2>
        </div>
        <a class="brutal-button secondary" href="/advice/">Browse all guides</a>
      </div>
      <div class="guide-grid">
        {guides.map((guide, index) => (
          <a class="guide-card brutal-card" href={`/advice/${guide.id}/`}>
            <div class:list={["guide-art", `art-${index + 1}`]}>
              <span>0{index + 1}</span>
              <i></i><i></i><i></i>
            </div>
            <div class="guide-body">
              <small>{guide.data.category} · {guide.data.readTime}</small>
              <h3>{guide.data.title}</h3>
              <p>{guide.data.summary}</p>
              <b>Read guide →</b>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="faq-section page-section">
    <div class="shell faq-grid">
      <div>
        <p class="eyebrow">The careful answers</p>
        <h2 class="section-title">Good<br />questions.</h2>
        <p>Height is personal. The answers should be precise without pretending the future is certain.</p>
      </div>
      <div class="faq-list">
        {faq.map((item, index) => (
          <details open={index === 0}>
            <summary><span>0{index + 1}</span>{item.question}<i>+</i></summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    overflow: hidden;
    border-bottom: 3px solid var(--color-ink);
    padding: clamp(3rem, 7vw, 7rem) 0;
    background: var(--color-paper);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.7fr);
    align-items: center;
    gap: clamp(3rem, 7vw, 6rem);
  }

  .hero-copy {
    display: grid;
    gap: 1.6rem;
  }

  .display-title em {
    position: relative;
    color: var(--color-coral);
    font-style: normal;
    text-shadow: 4px 4px 0 var(--color-ink);
    -webkit-text-stroke: 3px var(--color-ink);
  }

  .hero-lede {
    max-width: 650px;
    margin: 0;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 700;
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .text-link {
    font-size: 0.78rem;
    font-weight: 900;
    text-underline-offset: 5px;
    text-transform: uppercase;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-trust span {
    border-left: 3px solid var(--color-ink);
    padding: 0.25rem 0.7rem;
    font-size: 0.74rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-trust b {
    font-size: 1.05rem;
  }

  .hero-visual {
    position: relative;
    transform: rotate(2deg);
  }

  .ruler-card {
    overflow: hidden;
    background: var(--color-sky);
  }

  .ruler-top {
    display: flex;
    justify-content: space-between;
    border-bottom: 3px solid var(--color-ink);
    padding: 0.8rem 1rem;
    background: var(--color-sun);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .ruler-body {
    position: relative;
    min-height: 470px;
    padding: 1.2rem;
  }

  .ruler-line {
    display: grid;
    grid-template-columns: 42px 1fr;
    align-items: center;
    gap: 0.7rem;
    height: 61px;
    font-family: var(--font-display);
    font-size: 0.82rem;
  }

  .ruler-line i {
    height: 3px;
    background: var(--color-ink);
  }

  .ruler-line:nth-child(even) i {
    width: 76%;
  }

  .range-sticker {
    position: absolute;
    z-index: 2;
    right: 1rem;
    bottom: 2rem;
    display: grid;
    width: 150px;
    height: 150px;
    place-content: center;
    border: 3px solid var(--color-ink);
    border-radius: 50%;
    background: var(--color-lime);
    box-shadow: 6px 6px 0 var(--color-ink);
    text-align: center;
    text-transform: uppercase;
    transform: rotate(-8deg);
  }

  .range-sticker small {
    font-size: 0.62rem;
    font-weight: 900;
  }

  .range-sticker strong {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1;
  }

  .growth-arrow {
    position: absolute;
    top: 75px;
    right: 20px;
    width: 155px;
  }

  .hero-note {
    position: absolute;
    border: 3px solid var(--color-ink);
    padding: 0.55rem 0.7rem;
    background: white;
    box-shadow: 4px 4px 0 var(--color-ink);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .note-one {
    top: 20%;
    left: -2.5rem;
    transform: rotate(-8deg);
  }

  .note-two {
    right: -2rem;
    bottom: 12%;
    transform: rotate(6deg);
  }

  .principle-strip {
    overflow: hidden;
    border-bottom: 3px solid var(--color-ink);
    padding: 0.85rem 0;
    background: var(--color-ink);
    color: white;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 1.4rem;
    margin-inline: auto;
    padding-inline: 1rem;
    font-family: var(--font-display);
    font-size: clamp(0.8rem, 2vw, 1.05rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .marquee-track i {
    color: var(--color-lime);
    font-style: normal;
  }

  .calculator-section {
    background: #f3f0e5;
  }

  .calculator-heading,
  .method-heading,
  .guides-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .calculator-heading > div,
  .method-heading > div,
  .guides-heading > div {
    display: grid;
    gap: 1rem;
  }

  .calculator-heading > p,
  .method-heading > p {
    max-width: 430px;
    margin: 0 0 0.5rem;
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.55;
  }

  .history-section {
    border-top: 3px solid var(--color-ink);
    background: var(--color-paper);
  }

  .method-section {
    border-top: 3px solid var(--color-ink);
    background: var(--color-sun);
  }

  .method-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .method-card {
    display: flex;
    min-height: 390px;
    flex-direction: column;
    padding: 1.4rem;
  }

  .method-card > span {
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .method-card svg {
    width: 100px;
    margin: auto;
  }

  .method-card h3 {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: 1.65rem;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .method-card p {
    margin: 0;
    line-height: 1.55;
  }

  .lime-card { background: var(--color-lime); transform: rotate(-1deg); }
  .sky-card { background: var(--color-sky); transform: translateY(1rem) rotate(1deg); }
  .coral-card { background: var(--color-coral); transform: rotate(-0.6deg); }

  .method-link {
    margin-top: 3rem;
  }

  .guides-section {
    border-top: 3px solid var(--color-ink);
    background: var(--color-paper);
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .guide-card {
    display: flex;
    overflow: hidden;
    min-height: 490px;
    flex-direction: column;
    background: white;
    text-decoration: none;
    transition: transform 150ms ease;
  }

  .guide-card:hover {
    transform: translateY(-5px);
  }

  .guide-art {
    position: relative;
    min-height: 190px;
    overflow: hidden;
    border-bottom: 3px solid var(--color-ink);
  }

  .art-1 { background: var(--color-violet); }
  .art-2 { background: var(--color-lime); }
  .art-3 { background: var(--color-sky); }

  .guide-art span {
    position: relative;
    z-index: 2;
    display: inline-block;
    padding: 1rem;
    font-family: var(--font-display);
    font-size: 3.5rem;
  }

  .guide-art i {
    position: absolute;
    display: block;
    border: 3px solid var(--color-ink);
    background: var(--color-sun);
  }

  .guide-art i:nth-of-type(1) { right: -20px; bottom: -30px; width: 140px; height: 140px; border-radius: 50%; }
  .guide-art i:nth-of-type(2) { right: 80px; bottom: 20px; width: 50px; height: 100px; transform: rotate(18deg); }
  .guide-art i:nth-of-type(3) { top: 20px; right: 30px; width: 20px; height: 20px; background: var(--color-coral); transform: rotate(45deg); }

  .guide-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.25rem;
  }

  .guide-body small {
    font-size: 0.65rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .guide-body h3 {
    margin: 0.85rem 0 0.6rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .guide-body p {
    margin: 0;
    color: #555;
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .guide-body b {
    margin-top: auto;
    padding-top: 1.2rem;
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .faq-section {
    border-top: 3px solid var(--color-ink);
    background: var(--color-sky);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: clamp(2rem, 7vw, 6rem);
  }

  .faq-grid > div:first-child {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-grid > div:first-child > p:last-child {
    max-width: 360px;
    margin: 0;
    font-weight: 700;
    line-height: 1.55;
  }

  .faq-list {
    border-top: 3px solid var(--color-ink);
  }

  .faq-list details {
    border-bottom: 3px solid var(--color-ink);
  }

  .faq-list summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 0;
    font-weight: 900;
    cursor: pointer;
    list-style: none;
  }

  .faq-list summary span {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 2px solid var(--color-ink);
    background: var(--color-sun);
    font-size: 0.66rem;
  }

  .faq-list summary i {
    font-size: 1.5rem;
    font-style: normal;
  }

  .faq-list details[open] summary i {
    transform: rotate(45deg);
  }

  .faq-list details p {
    margin: -0.3rem 0 1.3rem 3.2rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      width: min(420px, 90%);
      margin-inline: auto;
    }

    .method-cards,
    .guide-grid {
      grid-template-columns: 1fr 1fr;
    }

    .guide-card:last-child,
    .method-card:last-child {
      grid-column: 1 / -1;
    }

    .method-card:last-child {
      min-height: 320px;
    }
  }

  @media (max-width: 700px) {
    .hero-actions,
    .calculator-heading,
    .method-heading,
    .guides-heading {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions .text-link {
      text-align: center;
    }

    .method-cards,
    .guide-grid,
    .faq-grid {
      grid-template-columns: 1fr;
    }

    .guide-card:last-child,
    .method-card:last-child {
      grid-column: auto;
    }

    .method-card,
    .method-card:last-child {
      min-height: 330px;
      transform: none;
    }

    .ruler-body {
      min-height: 420px;
    }
  }
</style>
